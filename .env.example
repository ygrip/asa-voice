# ASA Voice Sidecar — copy to .env for local runs. All keys map to app/config.py fields.

# STT (faster-whisper). distil-small.en = best accuracy/latency on CPU (faster than small.en, more
# accurate than base.en). Alternatives: base.en (lightest), small.en (most accurate). Not distil-large-v3.
STT_MODEL=distil-small.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
# Use all cores for CTranslate2 decode — biggest CPU latency win.
STT_CPU_THREADS=4
STT_NUM_WORKERS=1
STT_BEAM_SIZE=1
STT_BEST_OF=1
STT_VAD_FILTER=true
# Bias the decoder toward the assistant name + domain vocabulary (so "ASA" isn't heard as "Elsa").
STT_PROMPT=This is a voice command for ASA, the AI assistant inside Setara, a test management platform with projects, plans, builds, scenarios, squads, and tribes.
STT_HOTWORDS=ASA Setara
# Rolling-window streaming STT (WS /stt/stream): how often to re-decode the buffer. Lower = snappier
# live partials, more CPU. ~600ms balances latency vs decode cost on 4 cores.
STT_STREAM_INTERVAL_MS=600

# TTS (Pocket TTS, via app/services/tts_service.py adapter)
TTS_ENGINE=pocket-tts
TTS_DEFAULT_VOICE=asa_default
TTS_DEFAULT_MODEL=pocket-low
TTS_FORMAT=wav
TTS_SAMPLE_RATE=24000
TTS_MAX_TEXT_CHARS=600
# torch.compile the model once at startup (reduce-overhead) — first synth pays compile cost, rest faster.
TTS_COMPILE=true
# pocket-tts diffusion (latent-decode) steps. pocket-tts 2.1.0 already defaults to 1 (the minimum —
# the "10" figure is the full Kyutai DSM, not this model). Raise (>1) only to trade speed for quality.
TTS_LSD_DECODE_STEPS=1
# /tts/stream: coalesce this many generated chunks per network flush. 1 = lowest latency.
TTS_STREAM_COALESCE=1

# Auth: comma-separated client_id:secret pairs. Empty = open (dev mode, no key required).
# Same format as asa-rust-voice ALLOWED_CLIENTS.
ALLOWED_CLIENTS=setara-core:change-me-core,asa-ui:change-me-ui,local-dev:change-me-local

# Resource guards
# MAX_AUDIO_SECONDS: rolling-window buffer per utterance in streaming STT (keep short)
# MAX_UPLOAD_SECONDS: hard cap for file-upload STT (raise for long recordings)
MAX_AUDIO_SECONDS=20
MAX_UPLOAD_SECONDS=300
MAX_UPLOAD_MB=15
MAX_CONCURRENT_STT=1
MAX_CONCURRENT_TTS=1

TMP_DIR=/tmp/asa-voice
