# ASA Voice Sidecar - copy to .env for local runs. Every key maps to app/config.py.

APP_NAME=ASA Voice Sidecar

# Provider mode: local (faster_whisper + pocket_tts only, no external API key needed) | hosted |
# hybrid. Adapters exist for "faster_whisper"/"openai" (STT) and "pocket_tts"/"openai" (TTS) — the
# sidecar fails fast at startup if STT_PROVIDER/TTS_PROVIDER names an unimplemented provider.
ASA_VOICE_MODE=local
STT_PROVIDER=faster_whisper
STT_FALLBACK_PROVIDER=none
STT_ALLOW_PROVIDER_OVERRIDE=false
TTS_PROVIDER=pocket_tts
TTS_FALLBACK_PROVIDER=none

# OpenAI hosted STT for multipart POST /stt and disk-buffered WebSocket /stt/stream finals.
# /stt/raw remains the file-free faster-whisper path.
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_TIMEOUT_SECONDS=30
OPENAI_STT_BUFFER_DIRECTORY=/tmp/asa-voice/stt
OPENAI_STT_MAX_TEMP_BYTES=15728640
OPENAI_STT_ORPHAN_TTL_SECONDS=3600
OPENAI_STT_PROMPT=Common product terms: Setara, Raksara, scenario, test case, suite, execution, build, release plan, coverage, rerun failed, automation coverage, squad, tribe.

# Policy layer v1: request validation + in-memory per-client daily quota (seconds). Long PTT
# dictation already needs up to MAX_UPLOAD_SECONDS, so the per-request cap here defaults the same
# — tighten it for cost-sensitive hosted deployments.
MAX_STT_SECONDS_PER_REQUEST=300
MAX_STT_SECONDS_PER_CLIENT_PER_DAY=600

# OpenAI hosted TTS for POST /tts (complete synth) and /tts/stream (PCM streaming). tts-1 is the
# speed-oriented default; tts-1-hd trades latency for quality. OPENAI_TTS_INSTRUCTIONS only takes
# effect on gpt-4o-mini-tts — tts-1/tts-1-hd reject the param outright.
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_TIMEOUT_SECONDS=30
OPENAI_TTS_SPEED=1.0
OPENAI_TTS_INSTRUCTIONS=
OPENAI_TTS_COMPLETE_FORMAT=wav
OPENAI_TTS_STREAM_FORMAT=pcm
OPENAI_TTS_MAX_TEXT_CHARS=2000
HOSTED_TTS_MAX_CONCURRENT=4
MAX_TTS_CHARS_PER_CLIENT_PER_DAY=50000

# Cue service: asa-voice owns cue audio end-to-end (setara-core only proxies). CUE_EMBEDDED_PACK_DIR
# is populated at build time by the cue generator (not shipped yet) - absent until then, so lookups
# there miss cleanly and fall through to the runtime disk cache / regeneration below.
CUE_EMBEDDED_PACK_DIR=app/generated/cues
CUE_RUNTIME_CACHE_DIR=/tmp/asa-voice/cues
CUE_PACK_STRICT_MATCH=true
# Regeneration is a dev-only fallback tier; production defaults to fail (503) when no cue pack or
# disk cache is available. Policies: fail | degraded | regenerate | ignore.
CUE_RUNTIME_REGENERATION=false
CUE_PACK_MISMATCH_POLICY=fail

# STT (faster-whisper). distil-small.en = best accuracy/latency on CPU (faster than small.en, more
# accurate than base.en). Alternatives: base.en (lightest), small.en (most accurate). Not distil-large-v3.
STT_MODEL=distil-small.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
# Use all cores for CTranslate2 decode - biggest CPU latency win.
STT_CPU_THREADS=4
STT_NUM_WORKERS=1

# Rolling partials are display-only and optimized for response latency.
STT_PARTIAL_BEAM_SIZE=1
STT_PARTIAL_BEST_OF=1
STT_PARTIAL_WORD_TIMESTAMPS=true
STT_PARTIAL_VAD_FILTER=false

# Final decoding is the command-execution transcript and favors accuracy. beam_size/best_of/
# vad_filter/condition_on_previous/temperatures are mode-specific (STT_COMMAND_*/STT_DICTATION_*/
# STT_HANDSFREE_* below) - only word_timestamps stays a single global final-decode knob.
STT_FINAL_WORD_TIMESTAMPS=false

# Per-mode final-decode profiles (ASA STT accuracy/latency recovery plan, RC-06). The final profile
# used to always retry at STT_TEMPERATURES=[0.0,0.2,0.4] for every mode, multiplying latency
# whenever the quality gates rejected the greedy pass - wasteful for a short command. A single
# temperature (no fallback) went too far the other way: live testing showed temp=0.0 alone failing
# the log_prob/compression_ratio gate on real (non-noise) audio, with no fallback to recover it -
# faster-whisper then returns empty text, which the client reports as "Could not understand audio"
# even though the user was heard fine. Keep one cheap fallback step (only paid when temp=0.0 fails
# its own quality gate, not on every decode); dictation additionally keeps condition-on-previous
# (helps long-form continuity).
STT_COMMAND_BEAM_SIZE=2
STT_COMMAND_BEST_OF=2
STT_COMMAND_TEMPERATURES=[0.0,0.2]
STT_COMMAND_VAD_FILTER=false
STT_COMMAND_CONDITION_ON_PREVIOUS=false
STT_DICTATION_BEAM_SIZE=3
STT_DICTATION_BEST_OF=3
STT_DICTATION_TEMPERATURES=[0.0,0.2]
STT_DICTATION_VAD_FILTER=false
STT_DICTATION_CONDITION_ON_PREVIOUS=true
STT_HANDSFREE_BEAM_SIZE=2
STT_HANDSFREE_BEST_OF=2
STT_HANDSFREE_TEMPERATURES=[0.0,0.2]
STT_HANDSFREE_VAD_FILTER=false
STT_HANDSFREE_CONDITION_ON_PREVIOUS=false

# Command mode never runs a partial decoder; dictation/hands_free are final-only by default too -
# flush() blocks on any in-flight partial before the final decode can start, and a slow model can
# turn that into 7-12s+ of pure wait. Opt in per mode only if you need live captions and can widen
# STT_STREAM_INTERVAL_MS/STT_STREAM_MAX_PARTIAL_INTERVAL_MS (e.g. 2500/5000) to match.
STT_DICTATION_PARTIALS_ENABLED=false
STT_HANDSFREE_PARTIALS_ENABLED=false

# Decode quality and anti-repetition controls.
STT_NO_SPEECH_THRESHOLD=0.6
STT_VAD_MIN_SILENCE_MS=300
STT_REPETITION_PENALTY=1.15
# Hard n-gram blocking can corrupt legitimate repeated content (serial numbers, spelled-out words) -
# repetition_penalty (soft) + collapse_repeats() (post-hoc) already cover runaway Whisper loops.
STT_NO_REPEAT_NGRAM_SIZE=0
STT_COMPRESSION_RATIO_THRESHOLD=2.4
STT_LOG_PROB_THRESHOLD=-1.0

# Bias the decoder toward assistant and domain vocabulary (so "ASA" isn't heard as "Elsa").
STT_HOTWORDS=ASA Setara
# Rolling-window streaming STT (WS /stt/stream): how often to re-decode the buffer. Lower = snappier
# live partials, more CPU. ~600ms balances latency vs decode cost on 4 cores.
STT_STREAM_PROTOCOL_VERSION=2
STT_COMMAND_MAX_SECONDS=15
STT_HANDSFREE_MAX_SECONDS=30
STT_DICTATION_MAX_SECONDS=300
STT_FRAME_DURATION_MS=20
STT_STREAM_MAX_FRAME_BYTES=4096
STT_STREAM_MAX_SESSION_BYTES=9600000
STT_STREAM_QUEUE_MAX_MS=2000
STT_STREAM_HANDSHAKE_TIMEOUT_SECONDS=10
STT_STREAM_NO_AUDIO_IDLE_TIMEOUT_SECONDS=45
STT_PROVIDER_FINAL_TIMEOUT_SECONDS=300
STT_STREAM_INTERVAL_MS=600
STT_STREAM_MAX_PARTIAL_INTERVAL_MS=2400
STT_STREAM_RTF_SLOW_THRESHOLD=1.0
STT_STREAM_ENERGY_THRESHOLD=0.02
STT_STREAM_SILENCE_FLUSH_S=1.5

# TTS (Pocket TTS, via app/services/tts_service.py adapter)
TTS_ENGINE=pocket-tts
TTS_DEFAULT_VOICE=asa_default
TTS_DEFAULT_MODEL=pocket-low
TTS_SAMPLE_RATE=24000
TTS_MAX_TEXT_CHARS=600
# torch.compile the model once at startup (reduce-overhead) - first synth pays compile cost, rest faster.
TTS_COMPILE=true
# pocket-tts diffusion (latent-decode) steps. pocket-tts 2.1.0 already defaults to 1 (the minimum -
# the "10" figure is the full Kyutai DSM, not this model). Raise (>1) only to trade speed for quality.
TTS_LSD_DECODE_STEPS=1
# /tts/stream: coalesce this many generated chunks per network flush. 1 = lowest latency.
TTS_STREAM_COALESCE=1
# torch's own thread pool - pin below the container's cpus limit (see docker-compose.yml) so it
# doesn't oversubscribe the cgroup quota. Matches STT_CPU_THREADS rather than splitting the budget:
# STT and TTS rarely compute at the same instant within one voice turn, so a low value just starves
# single-request throughput for a mostly-theoretical isolation benefit.
TTS_CPU_THREADS=4

# Auth: comma-separated client_id:secret[:tier] pairs. tier defaults to "production" (no provider
# override) when omitted — mark a client "development"/"admin"/"test" to let it use provider=
# overrides on POST /stt (only honored when STT_ALLOW_PROVIDER_OVERRIDE=true). Empty ALLOWED_CLIENTS
# = open dev mode (no key required, every request treated as "development" tier).
# Same format as asa-rust-voice ALLOWED_CLIENTS (secret part), tier is sidecar-specific.
ALLOWED_CLIENTS=setara-core:change-me-core,asa-ui:change-me-ui,local-dev:change-me-local:development

# Resource guards
# MAX_AUDIO_SECONDS: composed via min(this, the mode's negotiated maxDurationSeconds) - a safety
# net against a misconfigured/future mode, not the effective per-mode cap (previously 20s here
# silently clipped every hands_free/dictation session onto the fragile tail-only fallback well
# before the client's advertised limit - setara-s94o STT quality incident).
# MAX_UPLOAD_SECONDS: hard cap for file-upload STT (raise for long recordings)
MAX_AUDIO_SECONDS=300
MAX_UPLOAD_SECONDS=300
MAX_UPLOAD_MB=15
# Provider-operation concurrency (preferred names).
LOCAL_STT_MAX_CONCURRENT=1
HOSTED_STT_MAX_CONCURRENT=4
TTS_MAX_CONCURRENT=1
# Legacy compatibility fallbacks, used only when the matching preferred value is unset.
MAX_CONCURRENT_STT=1
MAX_CONCURRENT_TTS=1

TMP_DIR=/tmp/asa-voice
